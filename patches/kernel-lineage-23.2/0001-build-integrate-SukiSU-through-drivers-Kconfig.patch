From 855d569946601534e726e7d19255fb3062a96ac3 Mon Sep 17 00:00:00 2001
From: Chinohana <chinohana@outlook.com>
Date: Wed, 22 Jul 2026 04:17:04 +0800
Subject: [PATCH] build: integrate SukiSU through drivers Kconfig

Linux 4.19 has no built-in KernelSU entry. Add the two canonical build-system hooks expected by the fixed SukiSU-Ultra v4.1.3 kernel directory symlink.
---
 drivers/Kconfig  | 2 ++
 drivers/Makefile | 1 +
 2 files changed, 3 insertions(+)

diff --git a/drivers/Kconfig b/drivers/Kconfig
index e0866ed..3afe38d 100644
--- a/drivers/Kconfig
+++ b/drivers/Kconfig
@@ -232,4 +232,6 @@ source "drivers/sensors/Kconfig"
 source "drivers/gpu/msm/Kconfig"
 
 source "drivers/energy_model/Kconfig"
+
+source "drivers/kernelsu/Kconfig"
 endmenu
diff --git a/drivers/Makefile b/drivers/Makefile
index 9a258f1..faea059 100644
--- a/drivers/Makefile
+++ b/drivers/Makefile
@@ -192,3 +192,4 @@ obj-$(CONFIG_UNISYS_VISORBUS)	+= visorbus/
 obj-$(CONFIG_SIOX)		+= siox/
 obj-$(CONFIG_GNSS)		+= gnss/
 obj-$(CONFIG_SENSORS_SSC)	+= sensors/
+obj-$(CONFIG_KSU)		+= kernelsu/
-- 
2.53.0.windows.2

