From d5b72a41535cc4d21d992537198f303a0477df6a Mon Sep 17 00:00:00 2001
From: Chinohana <chinohana@outlook.com>
Date: Wed, 22 Jul 2026 04:22:47 +0800
Subject: [PATCH 2/9] compat: tolerate missing MODULE_IMPORT_NS on Linux 4.19

Linux 4.19 predates the module namespace import metadata macro. Define it only when the target headers do not provide it.
---
 kernel/core/init.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/kernel/core/init.c b/kernel/core/init.c
index 68fa9d5..466b872 100644
--- a/kernel/core/init.c
+++ b/kernel/core/init.c
@@ -2,6 +2,10 @@
 #include <linux/fs.h>
 #include <linux/kobject.h>
 #include <linux/module.h>
+#ifndef MODULE_IMPORT_NS
+#define MODULE_IMPORT_NS(ns)
+#endif
+
 #include <linux/rcupdate.h>
 #include <linux/sched.h>
 #include <linux/workqueue.h>
-- 
