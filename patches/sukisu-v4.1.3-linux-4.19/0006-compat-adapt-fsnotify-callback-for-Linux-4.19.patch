From 5f9d3b269380516b965831fc5300bd257f748ff2 Mon Sep 17 00:00:00 2001
From: Chinohana <chinohana@outlook.com>
Date: Wed, 22 Jul 2026 04:22:48 +0800
Subject: [PATCH 6/9] compat: adapt fsnotify callback for Linux 4.19

Linux 4.19 fsnotify_ops uses handle_event instead of handle_inode_event. Translate the legacy callback arguments into the common inode handler.
---
 kernel/manager/pkg_observer.c | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/kernel/manager/pkg_observer.c b/kernel/manager/pkg_observer.c
index 512b992..dc537cf 100644
--- a/kernel/manager/pkg_observer.c
+++ b/kernel/manager/pkg_observer.c
@@ -35,8 +35,23 @@ static int ksu_handle_inode_event(struct fsnotify_mark *mark, u32 mask, struct i
     return 0;
 }
 
+#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 0, 0)
+static int ksu_handle_event(struct fsnotify_group *group, struct inode *inode, u32 mask, const void *data,
+                            int data_type, const unsigned char *file_name, u32 cookie,
+                            struct fsnotify_iter_info *iter_info)
+{
+    struct qstr name = QSTR_INIT(file_name, file_name ? strlen(file_name) : 0);
+
+    return ksu_handle_inode_event(NULL, mask, inode, NULL, file_name ? &name : NULL, cookie);
+}
+#endif
+
 static const struct fsnotify_ops ksu_ops = {
+#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 0, 0)
+    .handle_event = ksu_handle_event,
+#else
     .handle_inode_event = ksu_handle_inode_event,
+#endif
 };
 
 static int add_mark_on_inode(struct inode *inode, u32 mask, struct fsnotify_mark **out)
