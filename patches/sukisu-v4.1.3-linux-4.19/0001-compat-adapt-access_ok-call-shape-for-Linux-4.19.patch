From 0ff107cadb49b6a94a2a3bd626e94c75890f7c2f Mon Sep 17 00:00:00 2001
From: Chinohana <chinohana@outlook.com>
Date: Wed, 22 Jul 2026 04:22:47 +0800
Subject: [PATCH 1/9] compat: adapt access_ok call shape for Linux 4.19

Linux 4.19 access_ok requires a VERIFY_* direction argument. Preserve the existing KPM call sites for this baseline; the stable configuration keeps KPM disabled pending the direction-aware stage 4 audit.
---
 kernel/kpm/kpm.c | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/kernel/kpm/kpm.c b/kernel/kpm/kpm.c
index ea57221..84407e1 100644
--- a/kernel/kpm/kpm.c
+++ b/kernel/kpm/kpm.c
@@ -38,6 +38,18 @@
 #include "kpm.h"
 #include "compact.h"
 
+#if LINUX_VERSION_CODE < KERNEL_VERSION(5, 0, 0)
+static inline bool sukisu_access_ok_compat(const void __user *addr,
+                                           unsigned long size)
+{
+    return access_ok(VERIFY_READ, addr, size);
+}
+
+#undef access_ok
+#define access_ok(addr, size) \
+    sukisu_access_ok_compat((const void __user *)(addr), (size))
+#endif
+
 #define KPM_NAME_LEN 32
 #define KPM_ARGS_LEN 1024
 
