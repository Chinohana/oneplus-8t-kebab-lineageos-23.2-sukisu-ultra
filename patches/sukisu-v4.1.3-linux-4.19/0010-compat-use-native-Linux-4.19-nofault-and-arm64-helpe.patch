From 531acb3a8c3d3e535aa5413f95b4b15797818b26 Mon Sep 17 00:00:00 2001
From: Chinohana <chinohana@outlook.com>
Date: Wed, 22 Jul 2026 04:30:03 +0800
Subject: [PATCH] compat: use native Linux 4.19 nofault and arm64 helpers

Linux 4.19 provides min_t through linux/kernel.h, strncpy_from_user_nofault through linux/uaccess.h, and ARM64 untagged_addr through asm/memory.h. Include those native declarations without redefining any helper.
---
 kernel/sulog/event.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/kernel/sulog/event.c b/kernel/sulog/event.c
index 51d6fa84..06051427 100644
--- a/kernel/sulog/event.c
+++ b/kernel/sulog/event.c
@@ -1,8 +1,9 @@
 #include <asm/current.h>
+#include <asm/memory.h>
 #include <linux/compat.h>
 #include <linux/cred.h>
 #include <linux/gfp.h>
-#include <linux/minmax.h>
+#include <linux/kernel.h>
 #include <linux/overflow.h>
 #include <linux/sched/signal.h>
 #include <linux/slab.h>
-- 
2.53.0.windows.2

